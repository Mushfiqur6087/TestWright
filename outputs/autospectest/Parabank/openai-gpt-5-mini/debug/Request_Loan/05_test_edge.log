      "expected_result": "What should happen — specify pass or fail for boundary tests",
      "priority": "medium | low"
    }
  ],
  "summary": {
    "total": 0,
    "boundary": 0,
    "edge": 0,
    "medium_priority": 0,
    "low_priority": 0
  }
}


